# Colliers Flex — Zmienne środowiskowe
# Skopiuj ten plik do .env.local i uzupełnij wartości
# NIGDY nie commituj .env.local do repozytorium

# ── Supabase ─────────────────────────────────────────────────────────────────
# Znajdziesz w: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TWOJ_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # tylko server-side, nigdy nie ujawniaj

# ── Mapbox ────────────────────────────────────────────────────────────────────
# Znajdziesz w: account.mapbox.com → Tokens
# Token publiczny (scope: styles:read, tiles:read, geocoding)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# ── Resend (email) ────────────────────────────────────────────────────────────
# Znajdziesz w: resend.com → API Keys
RESEND_API_KEY=re_...
# Adres nadawcy (musi być zweryfikowaną domeną w Resend)
RESEND_FROM_EMAIL=flex@colliers.pl
# Adres odbiorcy zapytań ofertowych
RESEND_TO_EMAIL=jakub.bawol@colliers.com

# ── Google Analytics 4 ────────────────────────────────────────────────────────
# Znajdziesz w: analytics.google.com → Admin → Data Streams → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Serwis ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://flex.colliers.pl
# Lokalnie: http://localhost:3000
